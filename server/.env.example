# ===========================================
# Server Configuration
# ===========================================
PORT=5000
NODE_ENV=development

# ===========================================
# Database Configuration
# ===========================================
# MongoDB Connection String (get from MongoDB Atlas)
# Example: mongodb+srv://<username>:<password>@cluster.mongodb.net/text-to-learn
MONGO_URI=mongodb://localhost:27017/text-to-learn

# ===========================================
# Auth0 Configuration
# ===========================================
# Auth0 Domain (e.g., your-tenant.auth0.com)
AUTH0_DOMAIN=your-auth0-domain.auth0.com

# Auth0 Audience (your API identifier)
AUTH0_AUDIENCE=https://text-to-learn-api

# Auth0 Issuer URL (will be constructed as https://{AUTH0_DOMAIN}/)
# AUTH0_ISSUER is automatically derived from AUTH0_DOMAIN

# ===========================================
# API Keys
# ===========================================

# Google Gemini API Key (https://makersuite.google.com/app/apikey)
# Required for: Gemini/Gemma models, TTS, Course Generation
GEMINI_API_KEY=your_gemini_api_key_here

# YouTube Data API v3 (https://console.cloud.google.com/apis/credentials)
YOUTUBE_API_KEY=your_youtube_api_key_here

# ===========================================
# Frontend URL (for CORS)
# ===========================================
CLIENT_URL=http://localhost:5173

# ===========================================
# Adding New Providers
# ===========================================
# For additional LLM providers, add their API keys below:
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
# ===========================================
