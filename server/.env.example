# ===========================================
# LLM Provider Configuration
# ===========================================

# Select LLM provider: "openrouter", "gemini", or any registered provider
LLM_PROVIDER=openrouter

# OpenRouter API Key (https://openrouter.ai/keys)
# Supports: Nemotron, Gemma, Llama, Claude, and 100+ other models
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Google Gemini API Key (https://makersuite.google.com/app/apikey)
# Required for: Gemini/Gemma models, TTS
GEMINI_API_KEY=your_gemini_api_key_here

# ===========================================
# Other API Keys
# ===========================================

# YouTube Data API v3 (https://console.cloud.google.com/apis/credentials)
YOUTUBE_API_KEY=your_youtube_api_key_here

# ===========================================
# Adding New Providers
# ===========================================
# 1. Create provider class in llm_manager.py
# 2. Add to PROVIDER_REGISTRY
# 3. Add API key env variable: <PROVIDER_NAME>_API_KEY
# 4. Set LLM_PROVIDER to your new provider
#
# Example for Anthropic:
#   ANTHROPIC_API_KEY=your_key_here
#   LLM_PROVIDER=anthropic
# ===========================================
